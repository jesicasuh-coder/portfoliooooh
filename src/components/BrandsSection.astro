---
import SectionLayout from './SectionLayout.astro';
import ProjectCard from './ProjectCard.astro';
import Toc from './Toc.astro';
---

<SectionLayout
  id="brands"
  title="Brands"
>
  <Toc
    slot="sidebar-extra"
    items={[
      { label: 'CMF Matrix', href: '#cmf-matrix' },
      { label: 'Studio Pepper', href: '#studio-pepper' },
    ]}
  />
  <div class="cards">
    <div id="cmf-matrix">
      <ProjectCard
        image={`${import.meta.env.BASE_URL}images/card-cmf-matrix.png`}
        title="CMF-MATRIX"
        description={"AI-Powered Material Intelligence Platform\n\nThis started as a personal solution. I was frustrated with CMF research,\nso I built a tool to fix it.  Honestly? It's working so good."}
        ctaText="Coming soon !!"
        comingSoon={true}
      />
    </div>
    <div id="studio-pepper">
      <ProjectCard
        image={`${import.meta.env.BASE_URL}images/card-studio-pepper.png`}
        title="STUDIO PEPPER"
        description={"\"Adding flavor and spicy kicks\"\n\nBorn from a spilled pepper grinder and a \"what if\" moment in the kitchen, we built character-driven worlds. From our 8,888-piece digital collection to interactive racing games and physical art toys,"}
        ctaText="STUDIO PEPPER"
        href="https://www.behance.net/gallery/246509989/Studio-Pepper-Design-Origin-Story"
        external={true}
      />
    </div>
  </div>
</SectionLayout>

<style>
  .cards {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
</style>
