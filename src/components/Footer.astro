---
import SocialIcons from './SocialIcons.astro';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="divider"></div>
    <div class="footer-content">
      <p class="email">jessicasuh.design@gmail.com</p>
      <SocialIcons size={56} />
      <p class="copyright">&copy; 2026 Hyeyoung Suh. All rights reserved. · <a href={`${import.meta.env.BASE_URL}imprint`}>Impressum</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  .footer-inner {
    padding: 60px 0 40px;
  }

  .divider {
    border-top: 1px solid var(--color-text);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    padding-top: 60px;
  }

  .email {
    font-size: 20px;
    font-weight: 100;
    text-align: center;
  }

  .copyright {
    font-size: 14px;
    font-weight: 100;
    text-align: center;
    line-height: 1.219;
  }

  @media (max-width: 1023px) {
    .email {
      font-size: 18px;
    }
    .copyright {
      font-size: 13px;
    }
    .footer-inner {
      padding: 40px 0 60px;
    }
  }

  @media (max-width: 767px) {
    .email {
      font-size: 16px;
    }
    .copyright {
      font-size: 12px;
    }
    .footer-inner {
      padding: 32px 0 48px;
    }
    .footer-content {
      padding-top: 32px;
    }
  }
</style>
