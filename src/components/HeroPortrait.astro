<img
  src={`${import.meta.env.BASE_URL}images/portrait/jess-portrait.jpg`}
  alt="Jessica Suh portrait"
  class="portrait"
/>

<style>
  .portrait {
    width: 947px;
    height: auto;
  }

  @media (max-width: 1279px) {
    .portrait {
      width: 100%;
      max-width: 750px;
    }
  }

  @media (max-width: 1023px) {
    .portrait {
      max-width: 600px;
      margin: 0 auto;
    }
  }

  @media (max-width: 767px) {
    .portrait {
      max-width: 100%;
    }
  }
</style>
