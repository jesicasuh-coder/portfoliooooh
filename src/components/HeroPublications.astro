<style>
  .publications-label {
    text-align: center;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.219;
  }

  .publications-bar {
    background: var(--color-text);
    height: 168px;
    margin-top: 17px;
  }

  .publications-logos {
    display: flex;
    align-items: center;
    justify-content: space-around;
    height: 100%;
    padding: 0 60px;
  }

  .pub-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .pub-logo {
    height: 36px;
    width: auto;
    object-fit: contain;
  }

  .pub-link {
    font-size: 12px;
    font-weight: 400;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  @media (max-width: 1279px) {
    .publications-logos {
      padding: 0 30px;
    }
  }

  @media (max-width: 1023px) {
    .publications-bar {
      height: auto;
      padding: 24px 0;
    }
    .publications-logos {
      flex-wrap: wrap;
      gap: 20px 0;
      padding: 0 20px;
      justify-content: space-evenly;
    }
    .pub-item {
      flex: 0 0 33.33%;
      padding: 8px 0;
    }
    .pub-logo {
      height: 28px;
    }
  }

  @media (max-width: 767px) {
    .publications-logos {
      padding: 0 16px;
    }
    .pub-item {
      flex: 0 0 50%;
    }
    .pub-logo {
      height: 24px;
    }
    .pub-link {
      font-size: 10px;
    }
  }
</style>
