---
import SectionLayout from './SectionLayout.astro';
import ProjectCard from './ProjectCard.astro';
import Toc from './Toc.astro';
---

<SectionLayout
  id="highlights"
  title="Highlights"
>
  <Toc
    slot="sidebar-extra"
    items={[
      { label: 'Apollo Evo', href: '#apollo-evo' },
      { label: 'AUO CES Smart Cockpit', href: '#auo-ces' },
      { label: 'Apollo EVision S', href: '#apollo-evision' },
    ]}
  />
  <div class="cards">
    <div id="apollo-evo">
      <ProjectCard
        image={`${import.meta.env.BASE_URL}images/card-apollo-evo.png`}
        title="APOLLO EVO"
        description={"Limited-Edition Track-Only Hypercar\nGerman Rebellious engineering."}
        ctaText="APOLLO EVO"
        href="/highlights/apollo-evo"
      />
    </div>
    <div id="auo-ces">
      <ProjectCard
        image={`${import.meta.env.BASE_URL}images/card-auo-ces.png`}
        title="AUO CES 2025"
        description={"Infinite Future, Unlimited Possibilities.\nThe future of mobility in the AUO Smart Cockpit 2025,"}
        ctaText="AUO SMARTCOCKPIT CES 2025"
        href="/highlights/auo-smartcockpit"
      />
    </div>
    <div id="apollo-evision">
      <ProjectCard
        image={`${import.meta.env.BASE_URL}images/card-apollo-evision.png`}
        title="APOLLO EVISION S"
        description="Apollo's First EV Lineup in 4-Seater Sedan"
        ctaText="APOLLO EVISION S "
        href="/highlights/apollo-evision-s"
      />
    </div>
  </div>
</SectionLayout>

<style>
  .cards {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
</style>
