---
interface Props {
  columns?: string;
}

const { columns = '1fr 1fr' } = Astro.props;
---

<div class="image-pair" style={columns !== '1fr 1fr' ? `--pair-columns: ${columns}` : undefined}>
  <slot />
</div>

<style>
  .image-pair {
    display: grid;
    grid-template-columns: var(--pair-columns, 1fr 1fr);
    gap: 1px;
    margin: 24px 0;
  }

  .image-pair :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 767px) {
    .image-pair {
      grid-template-columns: 1fr;
    }
  }
</style>
