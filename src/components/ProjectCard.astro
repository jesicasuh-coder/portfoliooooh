---
interface Props {
  image: string;
  title: string;
  description: string;
  ctaText?: string;
  comingSoon?: boolean;
  href?: string;
  external?: boolean;
}

const { image, title, description, ctaText, comingSoon = false, href, external = false } = Astro.props;
---

{href ? (
  <a href={href} class="card-link" {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}>
    <div class="card">
      <img src={image} alt={title} class="card-image" />
      <div class="card-overlay">
        <h3 class="card-title">{title}</h3>
        <p class="card-description">{description}</p>
      </div>
      <div class="card-cta">
        <div class="cta-button">
          <svg class="cta-play" width="18" height="15" viewBox="0 0 18 15" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polygon points="0,0 18,7.5 0,15" fill="white" />
          </svg>
          <span class="cta-text">{ctaText || title}</span>
        </div>
      </div>
    </div>
  </a>
) : (
  <div class="card">
    <img src={image} alt={title} class="card-image" />
    <div class="card-overlay">
      <h3 class="card-title">{title}</h3>
      <p class="card-description">{description}</p>
    </div>
    {!comingSoon ? (
      <div class="card-cta">
        <div class="cta-button">
          <svg class="cta-play" width="18" height="15" viewBox="0 0 18 15" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polygon points="0,0 18,7.5 0,15" fill="white" />
          </svg>
          <span class="cta-text">{ctaText || title}</span>
        </div>
      </div>
    ) : (
      <div class="card-cta">
        <div class="cta-button">
          <span class="cta-text">{ctaText || 'Coming soon !!'}</span>
        </div>
      </div>
    )}
  </div>
)}

<style>
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card {
    position: relative;
    width: 100%;
    aspect-ratio: 952 / 559;
    overflow: hidden;
    background-color: #000;
    border-radius: 0;
  }

  .card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
    transition: opacity 0.4s ease;
  }

  .card:hover .card-image {
    opacity: 1;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px;
  }

  .card-title {
    font-size: 64px;
    font-weight: 600;
    line-height: 1.219;
    color: var(--color-card-text);
  }

  .card-description {
    font-size: 14px;
    font-weight: 100;
    line-height: 1.219;
    text-align: center;
    margin-top: 8px;
    max-width: 394px;
    white-space: pre-line;
  }

  .card-cta {
    position: absolute;
    bottom: 22px;
    right: 25px;
  }

  .cta-button {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    background: var(--color-btn-bg);
    border: 1px solid var(--color-btn-border);
    backdrop-filter: blur(4px);
  }

  .cta-play {
    flex-shrink: 0;
  }

  .cta-text {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.219;
  }

  @media (max-width: 1023px) {
    .card-title {
      font-size: 48px;
    }
    .card-overlay {
      padding: 24px;
    }
  }

  @media (max-width: 767px) {
    .card-title {
      font-size: clamp(28px, 8vw, 40px);
    }
    .card-description {
      font-size: 12px;
      max-width: 100%;
    }
    .card-overlay {
      padding: 16px;
    }
    .card-cta {
      bottom: 12px;
      right: 12px;
    }
    .cta-button {
      padding: 8px 16px;
      gap: 8px;
    }
    .cta-text {
      font-size: 12px;
    }
  }
</style>
