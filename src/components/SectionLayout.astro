---
interface Props {
  id: string;
  title: string;
  items?: { name: string; bold?: boolean }[];
}

const { id, title, items = [] } = Astro.props;
---

<section id={id} class="section">
  <div class="section-inner">
    <div class="divider"></div>
    <div class="section-grid">
      <div class="sidebar">
        <h2 class="section-title">{title}</h2>
        <slot name="sidebar-extra" />
        {items.length > 0 && (
          <ul class="section-items">
            {items.map((item) => (
              <li class:list={['section-item', { bold: item.bold }]}>{item.name}</li>
            ))}
          </ul>
        )}
      </div>
      <div class="content">
        <slot />
      </div>
    </div>
  </div>
</section>

<style>
  .section {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  .section-inner {
    padding-top: 80px;
  }

  .divider {
    border-top: 1px solid var(--color-text);
  }

  .section-grid {
    display: grid;
    grid-template-columns: 215px 1fr;
    gap: 44px;
    padding-top: 49px;
  }

  .sidebar {
    position: sticky;
    top: 100px;
    align-self: start;
  }

  .section-title {
    font-size: 24px;
    font-weight: 500;
    line-height: 1.219;
    white-space: pre-line;
  }

  .section-items {
    list-style: none;
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .section-item {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.219;
  }

  .section-item.bold {
    font-weight: 500;
  }

  @media (max-width: 1279px) {
    .section-grid {
      grid-template-columns: 180px 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 1023px) {
    .section-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .sidebar {
      position: static;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 8px 24px;
    }
    .section-items {
      margin-top: 0;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 4px 16px;
    }
    .section-inner {
      padding-top: 48px;
    }
  }

  @media (max-width: 767px) {
    .section-inner {
      padding-top: 32px;
    }
    .section-grid {
      padding-top: 24px;
      gap: 16px;
    }
    .section-title {
      font-size: 20px;
    }
  }
</style>
