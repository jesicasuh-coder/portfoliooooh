---
interface Props {
  src: string;
  title?: string;
  aspectRatio?: string;
}

const { src, title = 'Video', aspectRatio = '16/9' } = Astro.props;
---

<div class="video-embed" style={`aspect-ratio: ${aspectRatio}`}>
  <iframe
    src={src}
    title={title}
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>

<style>
  .video-embed {
    margin: 24px 0;
    box-shadow: 0px 0px 2px 2px rgba(0, 0, 0, 0.2);
  }

  .video-embed iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
